# Flask
SECRET_KEY=change-this-to-a-long-random-secret-key
FLASK_ENV=development
FLASK_DEBUG=1

# Database
# Default (easiest, zero setup) -> SQLite, used automatically if DATABASE_URL is not set
# For PostgreSQL, uncomment and edit the line below:
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/momenta_db

# Mail (optional - for real email notifications, using Gmail SMTP as example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Razorpay (optional - test mode keys, get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
